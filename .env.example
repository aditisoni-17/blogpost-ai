# ✅ SECURITY: This is an example .env file showing required variables
# Never commit your actual .env.local file to git
# Get real values from your Supabase dashboard and Google Cloud console

# ===== Supabase Configuration (NEXT_PUBLIC = exposed to frontend) =====
# Get these from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here

# ===== Server-only Keys (DO NOT use NEXT_PUBLIC_) =====
# Get these from Supabase dashboard → Settings → API → Service Role Key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here

# ===== Google AI Configuration (Server-only for security) =====
# ✅ IMPORTANT: This is NOT NEXT_PUBLIC_
# Using NEXT_PUBLIC_GOOGLE_AI_API_KEY exposes your key to the browser - DON'T DO IT
# Get this from Google Cloud Console → API Keys
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ===== Application Configuration =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Optional: Environment-specific settings =====
# NODE_ENV=development
# DEBUG=false
